  operator      User    @relation("ChangeOperator", fields: [operator_user_id], references: [id])
  target_person Person? @relation("ChangeTarget", fields: [target_person_id], references: [id])
  target_user   User?   @relation("ChangeTargetUser", fields: [target_user_id], references: [id])
  reviewer      User?   @relation("ChangeReviewer", fields: [approved_by], references: [id])

  @@index([person_id, created_at])
  @@index([clan_id, status, created_at])
  @@index([operator_user_id])
  @@map("family_relation_changes")
}

