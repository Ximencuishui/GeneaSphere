generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                      @id @default(uuid()) @map("id")
  phone                   String                      @unique @map("phone")
  password_hash           String                      @map("password_hash")
  created_at              DateTime                    @default(now()) @map("created_at")
  updated_at              DateTime                    @updatedAt @map("updated_at")
  ban_status              UserPlatformBanStatus       @default(NORMAL) @map("ban_status")
  ban_until               DateTime?                   @map("ban_until")
  last_login_ip           String?                     @map("last_login_ip")
  last_login_device       String?                     @map("last_login_device")
  avatar_url              String?                     @map("avatar_url")
  birth_date              DateTime?                   @map("birth_date")
  email                   String?                     @map("email")
  gender                  Gender?                     @map("gender")
  nickname                String?                     @map("nickname")
  wx_openid               String?                     @unique @map("wx_openid")
  wx_unionid              String?                     @map("wx_unionid")
  audit_logs              AuditLog[]
  bio_reviews_author      BioReview[]                 @relation("BioAuthor")
  bio_reviews_reviewer    BioReview[]                 @relation("BioReviewer")
  discussion_groups       DiscussionGroup[]           @relation("DiscussionGroupCreator")
  discussion_topics       GroupTopic[]                @relation("GroupTopicAuthor")
  discussion_replies      TopicReply[]                @relation("TopicReplyAuthor")
  buddy_requests_received BuddyMatchRecord[]          @relation("BuddyRequestReceiver")
  buddy_requests_sent     BuddyMatchRecord[]          @relation("BuddyRequestSender")
  childhood_places        ChildhoodPlace[]
  clans                   ClanMember[]
  admin_of                Clan[]                      @relation("AdminUser")
  purchase_logs           CreditPurchaseLog[]
  media_uploads           MediaArchive[]
  media_reviews           MediaReview[]
  merge_applications      MergeApplication[]          @relation("Applicant")
  application_reviews     MergeApplication[]          @relation("ApplicationReviewer")
  notifications           Notification[]
  photo_claims            PhotoClaimRecord[]
  print_orders            PrintOrder[]
  tool_usage_logs         ToolUsageLog[]
  ocr_usage_logs          OcrUsageLog[]
    pdf_import_logs         PdfImportLog[]
  credit                  UserCredit?
  setting                 UserSetting?
  vip_orders              VideoVipOrder[]
  video_projects          VideoProject[]
  migration_events        MigrationEvent[]            @relation("MigrationEventCreator")
  location_media_links    MigrationLocationMedia[]    @relation("LocationMediaLinker")
  albums                  UserAlbum[]
  personal_photos         UserPhoto[]
  personal_messages       UserMessage[]
  storage                 UserStorage?
  lineage_video_projects  LineageVideoProject[]
  family_book_projects    FamilyBookProject[]
  created_invite_qrcodes  InviteQrcode[]
  scanned_sessions        VerificationSession[]       @relation("ScannedSession")
  inviter_sessions        VerificationSession[]       @relation("InviterSession")
  given_endorsements      Endorsement[]
  modification_requests   PersonModificationRequest[] @relation("ModificationRequester")

  // ==================== 柔性家庭关系更新 ====================
  person_links            PersonUserLink[]
  relation_changes        FamilyRelationChange[]     @relation("ChangeOperator")
  relation_targeted       FamilyRelationChange[]     @relation("ChangeTargetUser")
  relation_reviewed       FamilyRelationChange[]     @relation("ChangeReviewer")
  relation_privacy_pref   RelationPrivacyPreference?
  custody_records_created ChildCustodyRecord[]

  @@index([ban_status])
  @@index([wx_openid])
  @@map("users")
}

model Clan {
  id                       BigInt                   @id @default(autoincrement()) @map("id")
  name                     String                   @map("name")
  description              String?                  @map("description")
  admin_user_id            String                   @map("admin_user_id")
  settings_json            Json?                    @map("settings_json")
  created_at               DateTime                 @default(now()) @map("created_at")
  updated_at               DateTime                 @updatedAt @map("updated_at")
  status                   ClanPlatformStatus       @default(NORMAL) @map("status")
  register_ip              String?                  @map("register_ip")
  reviewed_at              DateTime?                @map("reviewed_at")
  reviewer_id              BigInt?                  @map("reviewer_id")
  audit_logs               AuditLog[]
  clan_balance             ClanBalance?
  members                  ClanMember[]
  admin_user               User                     @relation("AdminUser", fields: [admin_user_id], references: [id], onDelete: Cascade)
  data_snapshots           DataSnapshot[]
  shared_credits           FamilySharedCredit[]
  families                 FamilyUnit[]
  media                    MediaArchive[]
    pdf_import_logs         PdfImportLog[]
  merge_applications       MergeApplication[]
  persons                  Person[]
  print_orders             PrintOrder[]
  privacy_settings         PrivacySetting?
  recharge_orders          RechargeOrder[]
  recharge_records         RechargeRecord[]
  sms_send_records         SmsSendRecord[]
  xipai                    Xipai[]
  video_projects           VideoProject[]
  migration_events         MigrationEvent[]
  migration_location_media MigrationLocationMedia[]
  family_book_projects     FamilyBookProject[]

  // ==================== 柔性家庭关系更新 ====================
  relation_changes FamilyRelationChange[]
  marriages        MarriageHistory[]
  custody_records  ChildCustodyRecord[]

  @@index([status])
  @@index([register_ip])
  @@map("clans")
}

model Person {
  id                      BigInt                     @id @default(autoincrement()) @map("id")
  clan_id                 BigInt                     @map("clan_id")
  full_name               String                     @map("full_name")
  gender                  Gender                     @map("gender")
  birth_date              DateTime?                  @map("birth_date")
  death_date              DateTime?                  @map("death_date")
  is_living               Boolean                    @default(true) @map("is_living")
  birth_place             String?                    @map("birth_place")
  birth_lat               Float?                     @map("birth_lat")
  birth_lng               Float?                     @map("birth_lng")
  death_place             String?                    @map("death_place")
  death_lat               Float?                     @map("death_lat")
  death_lng               Float?                     @map("death_lng")
  avatar_url              String?                    @map("avatar_url")
  thumbnail_url           String?                    @map("thumbnail_url")
  migration_branch        String?                    @map("migration_branch")
  created_at              DateTime                   @default(now()) @map("created_at")
  updated_at              DateTime                   @updatedAt @map("updated_at")
  bio_reviews             BioReview[]
  children_in             FamilyChild[]              @relation("ChildRelation")
  husband_in              FamilyUnit[]               @relation("HusbandRelation")
  wife_in                 FamilyUnit[]               @relation("WifeRelation")
  media_links             MediaPersonLink[]
  matched_persons         MergeApplication[]         @relation("MatchedPerson")
  ancestor_links          PersonAncestry[]           @relation("AncestorRelation")
  descendant_links        PersonAncestry[]           @relation("DescendantRelation")
  video_projects          VideoProject[]
  migration_events        MigrationEvent[]
  clan                    Clan                       @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  lineage_video_projects  LineageVideoProject[]
  lineage_video_materials LineageVideoMaterialLink[]
  family_book_projects    FamilyBookProject[]        @relation("FamilyBookStartPerson")
  verification_sessions   VerificationSession[]

  // ==================== 柔性家庭关系更新 ====================
  user_links           PersonUserLink[]
  changes_as_subject   FamilyRelationChange[] @relation("ChangeSubject")
  changes_as_target    FamilyRelationChange[] @relation("ChangeTarget")
  marriages_as_subject MarriageHistory[]      @relation("MarriageSubject")
  marriages_as_spouse  MarriageHistory[]      @relation("MarriageSpouse")
  custody_as_child     ChildCustodyRecord[]   @relation("CustodyChild")
  custody_as_parent    ChildCustodyRecord[]   @relation("CustodyParent")

  @@index([clan_id, migration_branch])
  @@map("persons")
}

model FamilyUnit {
  id         BigInt        @id @default(autoincrement()) @map("id")
  clan_id    BigInt        @map("clan_id")
  husband_id BigInt?       @map("husband_id")
  wife_id    BigInt?       @map("wife_id")
  union_type String?       @default("normal") @map("union_type")
  children   FamilyChild[]
  clan       Clan          @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  husband    Person?       @relation("HusbandRelation", fields: [husband_id], references: [id])
  wife       Person?       @relation("WifeRelation", fields: [wife_id], references: [id])

  @@map("family_units")
}

model FamilyChild {
  id          BigInt     @id @default(autoincrement()) @map("id")
  family_id   BigInt     @map("family_id")
  child_id    BigInt     @map("child_id")
  birth_order Int        @map("birth_order")
  child       Person     @relation("ChildRelation", fields: [child_id], references: [id], onDelete: Cascade)
  family      FamilyUnit @relation(fields: [family_id], references: [id], onDelete: Cascade)

  @@map("family_children")
}

model PersonAncestry {
  ancestor_id   BigInt @map("ancestor_id")
  descendant_id BigInt @map("descendant_id")
  depth         Int    @map("depth")
  ancestor      Person @relation("AncestorRelation", fields: [ancestor_id], references: [id], onDelete: Cascade)
  descendant    Person @relation("DescendantRelation", fields: [descendant_id], references: [id], onDelete: Cascade)

  @@id([ancestor_id, descendant_id])
  @@map("person_ancestry")
}

model MediaArchive {
  id                           BigInt                     @id @default(autoincrement()) @map("id")
  clan_id                      BigInt                     @map("clan_id")
  uploader_id                  String                     @map("uploader_id")
  file_url                     String                     @map("file_url")
  taken_year                   Int?                       @map("taken_year")
  taken_location               String?                    @map("taken_location")
  description                  String?                    @map("description")
  created_at                   DateTime                   @default(now()) @map("created_at")
  updated_at                   DateTime                   @updatedAt @map("updated_at")
  file_size                    BigInt                     @default(0) @map("file_size")
  media_type                   String                     @default("image") @map("media_type")
  display_url                  String?                    @map("display_url")
  thumb_url                    String?                    @map("thumb_url")
  original_key                 String?                    @map("original_key")
  clan                         Clan                       @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  uploader                     User                       @relation(fields: [uploader_id], references: [id], onDelete: Cascade)
  person_links                 MediaPersonLink[]
  reviews                      MediaReview[]
  video_material_links         VideoMaterialLink[]
  lineage_video_material_links LineageVideoMaterialLink[]
  migration_location_media     MigrationLocationMedia[]

  @@map("media_archives")
}

model MediaPersonLink {
  media_id  BigInt       @map("media_id")
  person_id BigInt       @map("person_id")
  media     MediaArchive @relation(fields: [media_id], references: [id], onDelete: Cascade)
  person    Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@id([media_id, person_id])
  @@map("media_person_links")
}

model SearchPost {
  id             BigInt           @id @default(autoincrement()) @map("id")
  origin_place   String           @map("origin_place")
  xipai_keywords String[]         @map("xipai_keywords")
  contact_info   String           @map("contact_info")
  created_by     String           @map("created_by")
  created_at     DateTime         @default(now()) @map("created_at")
  updated_at     DateTime         @updatedAt @map("updated_at")
  status         SearchPostStatus @default(PUBLISHED) @map("status")
  reviewed_at    DateTime?        @map("reviewed_at")
  reviewer_id    BigInt?          @map("reviewer_id")
  reject_reason  String?          @map("reject_reason")

  @@index([origin_place])
  @@index([xipai_keywords])
  @@index([status])
  @@map("search_posts")
}

model ClanMember {
  id        BigInt   @id @default(autoincrement()) @map("id")
  clan_id   BigInt   @map("clan_id")
  user_id   String   @map("user_id")
  role      Role     @default(VIEWER) @map("role")
  joined_at DateTime @default(now()) @map("joined_at")
  clan      Clan     @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([clan_id, user_id])
  @@map("clan_members")
}

model MediaReview {
  id            BigInt       @id @default(autoincrement()) @map("id")
  media_id      BigInt       @map("media_id")
  reviewer_id   String?      @map("reviewer_id")
  status        ReviewStatus @default(PENDING) @map("status")
  reject_reason String?      @map("reject_reason")
  reviewed_at   DateTime?    @map("reviewed_at")
  created_at    DateTime     @default(now()) @map("created_at")
  media         MediaArchive @relation(fields: [media_id], references: [id], onDelete: Cascade)
  reviewer      User?        @relation(fields: [reviewer_id], references: [id])

  @@map("media_reviews")
}

model BioReview {
  id            BigInt       @id @default(autoincrement()) @map("id")
  person_id     BigInt       @map("person_id")
  author_id     String       @map("author_id")
  title         String       @map("title")
  content       String       @map("content")
  reviewer_id   String?      @map("reviewer_id")
  status        ReviewStatus @default(PENDING) @map("status")
  reject_reason String?      @map("reject_reason")
  reviewed_at   DateTime?    @map("reviewed_at")
  created_at    DateTime     @default(now()) @map("created_at")
  author        User         @relation("BioAuthor", fields: [author_id], references: [id], onDelete: Cascade)
  person        Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)
  reviewer      User?        @relation("BioReviewer", fields: [reviewer_id], references: [id])

  @@map("bio_reviews")
}

model MergeApplication {
  id                BigInt            @id @default(autoincrement()) @map("id")
  clan_id           BigInt            @map("clan_id")
  applicant_id      String            @map("applicant_id")
  origin_place      String            @map("origin_place")
  xipai_info        String[]          @map("xipai_info")
  ancestor_name     String?           @map("ancestor_name")
  migration_history String?           @map("migration_history")
  matched_person_id BigInt?           @map("matched_person_id")
  match_score       Int?              @map("match_score")
  match_details     String?           @map("match_details")
  status            ApplicationStatus @default(PENDING) @map("status")
  reject_reason     String?           @map("reject_reason")
  merge_target_id   BigInt?           @map("merge_target_id")
  reviewed_by       String?           @map("reviewed_by")
  reviewed_at       DateTime?         @map("reviewed_at")
  created_at        DateTime          @default(now()) @map("created_at")
  applicant         User              @relation("Applicant", fields: [applicant_id], references: [id], onDelete: Cascade)
  clan              Clan              @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  matched_person    Person?           @relation("MatchedPerson", fields: [matched_person_id], references: [id])
  reviewer          User?             @relation("ApplicationReviewer", fields: [reviewed_by], references: [id])

  @@map("merge_applications")
}

model PrivacySetting {
  id                      BigInt   @id @default(autoincrement()) @map("id")
  clan_id                 BigInt   @unique @map("clan_id")
  allow_visitor_deceased  Boolean  @default(false) @map("allow_visitor_deceased")
  max_generations_visible Int      @default(5) @map("max_generations_visible")
  hide_living_photos      Boolean  @default(true) @map("hide_living_photos")
  hide_living_spouses     Boolean  @default(true) @map("hide_living_spouses")
  enable_relative_verify  Boolean  @default(false) @map("enable_relative_verify")
  verify_questions        String[] @default([]) @map("verify_questions")
  verify_max_attempts     Int      @default(3) @map("verify_max_attempts")
  clan                    Clan     @relation(fields: [clan_id], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model UserSetting {
  id                              BigInt   @id @default(autoincrement()) @map("id")
  user_id                         String   @unique @map("user_id")
  allow_cross_clan_friend_finding Boolean  @default(true) @map("allow_cross_clan_friend_finding")
  show_childhood_location         Boolean  @default(false) @map("show_childhood_location")
  allow_photo_find_me             Boolean  @default(true) @map("allow_photo_find_me")
  allow_annotation_for_match      Boolean  @default(true) @map("allow_annotation_for_match")
  enable_in_app_notification      Boolean  @default(true) @map("enable_in_app_notification")
  enable_sms_notification         Boolean  @default(false) @map("enable_sms_notification")
  phone_bound                     String?  @map("phone_bound")
  created_at                      DateTime @default(now()) @map("created_at")
  updated_at                      DateTime @updatedAt @map("updated_at")
  user                            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Xipai {
  id         BigInt  @id @default(autoincrement()) @map("id")
  clan_id    BigInt  @map("clan_id")
  generation Int     @map("generation")
  character  String  @map("character")
  note       String? @map("note")
  clan       Clan    @relation(fields: [clan_id], references: [id], onDelete: Cascade)

  @@unique([clan_id, generation])
  @@map("xipai")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement()) @map("id")
  clan_id     BigInt?  @map("clan_id")
  user_id     String   @map("user_id")
  action      String   @map("action")
  target_type String?  @map("target_type")
  target_id   String?  @map("target_id")
  details     String?  @map("details")
  ip_address  String?  @map("ip_address")
  created_at  DateTime @default(now()) @map("created_at")
  clan        Clan?    @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([clan_id, created_at])
  @@index([user_id])
  @@index([action])
  @@map("audit_logs")
}

model Notification {
  id          BigInt           @id @default(autoincrement()) @map("id")
  user_id     String           @map("user_id")
  clan_id     BigInt?          @map("clan_id")
  type        NotificationType @map("type")
  title       String           @map("title")
  content     String           @map("content")
  target_type String?          @map("target_type")
  target_id   String?          @map("target_id")
  is_read     Boolean          @default(false) @map("is_read")
  read_at     DateTime?        @map("read_at")
  created_at  DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, created_at])
  @@index([clan_id])
  @@map("notifications")
}

model PlatformAdmin {
  id             BigInt                 @id @default(autoincrement()) @map("id")
  username       String                 @unique @map("username")
  password_hash  String                 @map("password_hash")
  role           PlatformRole           @default(operator) @map("role")
  real_name      String?                @map("real_name")
  phone          String?                @map("phone")
  status         PlatformAdminStatus    @default(active) @map("status")
  last_login_at  DateTime?              @map("last_login_at")
  last_login_ip  String?                @map("last_login_ip")
  created_at     DateTime               @default(now()) @map("created_at")
  updated_at     DateTime               @updatedAt @map("updated_at")
  operation_logs PlatformOperationLog[]

  @@index([role])
  @@map("platform_admins")
}

model PlatformOperationLog {
  id          BigInt        @id @default(autoincrement()) @map("id")
  admin_id    BigInt        @map("admin_id")
  action_type String        @map("action_type")
  target_type String?       @map("target_type")
  target_id   String?       @map("target_id")
  detail      Json?         @map("detail")
  ip_address  String?       @map("ip_address")
  status      String        @default("success") @map("status")
  created_at  DateTime      @default(now()) @map("created_at")
  admin       PlatformAdmin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id, created_at])
  @@index([action_type])
  @@index([target_type])
  @@map("platform_operation_logs")
}

model GlobalSetting {
  setting_key   String   @id @map("setting_key")
  setting_value Json     @map("setting_value")
  description   String?  @map("description")
  updated_at    DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

model RechargeOrder {
  id             BigInt              @id @default(autoincrement()) @map("id")
  clan_id        BigInt              @map("clan_id")
  user_id        String              @map("user_id")
  amount         Float               @map("amount")
  bonus_amount   Float               @default(0) @map("bonus_amount")
  payment_method String              @default("wechat") @map("payment_method")
  transaction_no String?             @map("transaction_no")
  status         RechargeOrderStatus @default(SUCCESS) @map("status")
  created_at     DateTime            @default(now()) @map("created_at")
  clan           Clan                @relation(fields: [clan_id], references: [id], onDelete: Cascade)

  @@index([clan_id])
  @@index([status])
  @@index([created_at])
  @@map("recharge_orders")
}

model DataSnapshot {
  id                   BigInt   @id @default(autoincrement()) @map("id")
  clan_id              BigInt   @map("clan_id")
  data                 Json     @map("data")
  reason               String   @map("reason")
  created_by           String   @map("created_by")
  created_at           DateTime @default(now()) @map("created_at")
  expires_at           DateTime @map("expires_at")
  applicant_clan_id    BigInt?  @map("applicant_clan_id")
  branch_root_id       BigInt?  @map("branch_root_id")
  is_reverted          Boolean  @default(false) @map("is_reverted")
  merge_application_id BigInt?  @map("merge_application_id")
  merge_target_id      BigInt?  @map("merge_target_id")
  operation_type       String?  @map("operation_type")
  clan                 Clan     @relation(fields: [clan_id], references: [id], onDelete: Cascade)

  @@index([clan_id, created_at])
  @@index([merge_application_id])
  @@map("data_snapshots")
}

model PrintOrder {
  id                     BigInt                 @id @default(autoincrement()) @map("id")
  clan_id                BigInt                 @map("clan_id")
  user_id                String                 @map("user_id")
  specification          String                 @map("specification")
  quantity               Int                    @map("quantity")
  amount                 Float                  @map("amount")
  status                 OrderStatus            @default(PENDING) @map("status")
  tracking_no            String?                @map("tracking_no")
  created_at             DateTime               @default(now()) @map("created_at")
  updated_at             DateTime               @updatedAt @map("updated_at")
  tracking_company       String?                @map("tracking_company")
  refund_amount          Float                  @default(0) @map("refund_amount")
  refund_reason          String?                @map("refund_reason")
  refunded_at            DateTime?              @map("refunded_at")
  refund_status          PrintOrderRefundStatus @default(NONE) @map("refund_status")
  shipping_address       Json?                  @map("shipping_address")
  clan                   Clan                   @relation(fields: [clan_id], references: [id], onDelete: Cascade)
  user                   User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  family_book_project    FamilyBookProject?     @relation("FamilyBookPrintOrder", fields: [family_book_project_id], references: [id])
  family_book_project_id BigInt?                @unique @map("family_book_project_id")

  @@map("print_orders")
}

model ClanBalance {
  id                    BigInt   @id @default(autoincrement()) @map("id")
  clan_id               BigInt   @unique @map("clan_id")
  balance               Decimal  @default(0) @map("balance") @db.Decimal(10, 2)
  total_recharged       Decimal  @default(0) @map("total_recharged") @db.Decimal(10, 2)
  total_consumed        Decimal  @default(0) @map("total_consumed") @db.Decimal(10, 2)
  low_balance_threshold Decimal  @default(20) @map("low_balance_threshold") @db.Decimal(10, 2)
  created_at            DateTime @default(now()) @map("created_at")
  updated_at            DateTime @updatedAt @map("updated_at")
  clan                  Clan     @relation(fields: [clan_id], references: [id], onDelete: Cascade)

  @@map("clan_balances")
}

model RechargeRecord {
  id             BigInt         @id @default(autoincrement()) @map("id")
  clan_id        BigInt         @map("clan_id")
  operator_id    String         @map("operator_id")
  amount         Decimal        @map("amount") @db.Decimal(10, 2)
  bonus          Decimal        @default(0) @map("bonus") @db.Decimal(10, 2)
  payment_method String?        @map("payment_method")
  trade_no       String?        @map("trade_no")
  status         RechargeStatus @default(PENDING) @map("status")
  created_at     DateTime       @default(now()) @map("created_at")
  clan           Clan           @relation(fields: [clan_id], references: [id], onDelete: Cascade)

  @@index([clan_id])
  @@index([status])
