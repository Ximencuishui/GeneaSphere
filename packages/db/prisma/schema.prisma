// 视频生成项目表
model VideoProject {
  id               BigInt             @id @default(autoincrement()) @map("id")
  clan_id          BigInt             @map("clan_id")
  requester_id     String             @map("requester_id")
  target_person_id BigInt             @map("target_person_id")
  status           VideoProjectStatus @default(queued) @map("status")
  queue_position   Int                @default(0) @map("queue_position")
  priority         Boolean            @default(false) @map("priority")
  paid_amount      Decimal            @default(0.00) @map("paid_amount") @db.Decimal(10, 2)
  video_url        String?            @map("video_url") @db.VarChar(500)
  duration_seconds Int?               @map("duration_seconds")
