// 家庭关系变更历史表
model FamilyRelationChange {
  id               BigInt               @id @default(autoincrement()) @map("id")
  clan_id          BigInt               @map("clan_id")
  person_id        BigInt               @map("person_id")
  operator_user_id String               @map("operator_user_id")
  change_type      RelationChangeType   @map("change_type")
  previous_state   Json?                @map("previous_state")
  current_state    Json                 @map("current_state")
  privacy_level    RelationPrivacyLevel @default(admin) @map("privacy_level")
  change_reason    String?              @map("change_reason")
  target_person_id BigInt?              @map("target_person_id")
  target_user_id   String?              @map("target_user_id")
  status           RelationChangeStatus @default(auto_approved) @map("status")
  approved_by      String?              @map("approved_by")
  reviewed_at      DateTime?            @map("reviewed_at")
  reject_reason    String?              @map("reject_reason")
  needs_manual     Boolean              @default(false) @map("needs_manual")
