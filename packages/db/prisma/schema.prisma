// ==================== 族谱邀请与身份验证 H5 相关 ====================

// 邀请二维码记录表
model InviteQrcode {
  id         BigInt             @id @default(autoincrement()) @map("id")
  clan_id    BigInt             @map("clan_id")
  creator_id String             @map("creator_id")
  code       String             @unique @map("code")
  purpose    String             @default("clan_invite") @map("purpose") // clan_invite | peer_verify
  inviter_id BigInt?            @map("inviter_id")
  expire_at  DateTime           @map("expire_at")
  scan_count Int                @default(0) @map("scan_count")
  status     InviteQrcodeStatus @default(ACTIVE) @map("status")
  created_at DateTime           @default(now()) @map("created_at")
  updated_at DateTime           @updatedAt @map("updated_at")

  creator  User                  @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  sessions VerificationSession[]

  @@index([clan_id, expire_at])
  @@index([creator_id, created_at])
  @@index([status])
  @@map("invite_qrcodes")
}

// 验证会话表
model VerificationSession {
  id                BigInt             @id @default(autoincrement()) @map("id")
  qrcode_id         BigInt?            @map("qrcode_id")
  inviter_user_id   String?            @map("inviter_user_id")
  scanner_openid    String             @map("scanner_openid")
  scanner_phone     String?            @map("scanner_phone")
  scanner_nickname  String?            @map("scanner_nickname")
  scanner_avatar    String?            @map("scanner_avatar")
  clan_id           BigInt             @map("clan_id")
  status            VerificationStatus @default(PENDING) @map("status")
  verify_method     VerifyMethod?      @map("verify_method")
  expire_at         DateTime           @map("expire_at")
  scanned_user_id   String?            @map("scanned_user_id")
  matched_person_id BigInt?            @map("matched_person_id")
  submitted_info    Json?              @map("submitted_info")
  passed_at         DateTime?          @map("passed_at")
  fail_reason       String?            @map("fail_reason")
  created_at        DateTime           @default(now()) @map("created_at")
  updated_at        DateTime           @updatedAt @map("updated_at")

  qrcode         InviteQrcode? @relation(fields: [qrcode_id], references: [id], onDelete: SetNull)
  matched_person Person?       @relation(fields: [matched_person_id], references: [id], onDelete: SetNull)
  scanned_user   User?         @relation("ScannedSession", fields: [scanned_user_id], references: [id], onDelete: SetNull)
  inviter_user   User?         @relation("InviterSession", fields: [inviter_user_id], references: [id], onDelete: SetNull)
  quiz_attempts  QuizAttempt[]
  endorsements   Endorsement[]

  @@index([scanner_openid, status])
  @@index([clan_id, status])
  @@index([expire_at, status])
  @@map("verification_sessions")
}

// 知识问答记录表
model QuizAttempt {
  id             BigInt         @id @default(autoincrement()) @map("id")
  session_id     BigInt         @map("session_id")
  question       String         @map("question") @db.Text
  options        Json           @map("options")
  correct_answer String         @map("correct_answer")
  difficulty     QuizDifficulty @default(MEDIUM) @map("difficulty")
  category       String         @default("direct_elder") @map("category")
  user_answer    String?        @map("user_answer")
  is_correct     Boolean?       @map("is_correct")
  retry_count    Int            @default(0) @map("retry_count")
  answered_at    DateTime?      @map("answered_at")
  created_at     DateTime       @default(now()) @map("created_at")

  session VerificationSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("quiz_attempts")
}

// 熟人背书记录表
model Endorsement {
  id               BigInt             @id @default(autoincrement()) @map("id")
  session_id       BigInt             @map("session_id")
  endorser_user_id String             @map("endorser_user_id")
  result           EndorsementResult? @map("result")
  responded_at     DateTime?          @map("responded_at")
  reject_reason    String?            @map("reject_reason")
  expire_at        DateTime           @map("expire_at")
  created_at       DateTime           @default(now()) @map("created_at")

  session  VerificationSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  endorser User                @relation(fields: [endorser_user_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([endorser_user_id, created_at])
  @@map("endorsements")
}

// 族人信息修改申请表
model PersonModificationRequest {
