// 家庭图册项目表
model FamilyBookProject {
  id              BigInt                  @id @default(autoincrement()) @map("id")
  user_id         String                  @map("user_id")
  clan_id         BigInt                  @map("clan_id")
  start_person_id BigInt                  @map("start_person_id")
  generations     Int                     @default(3) @map("generations")
  include_spouse  Boolean                 @default(true) @map("include_spouse")
  grouping        FamilyBookGrouping      @default(family) @map("grouping")
  selected_fields String[]                @default(["name", "photo", "birth", "bio"]) @map("selected_fields")
  cover_template  FamilyBookCoverTemplate @default(red) @map("cover_template")
  title           String                  @map("title") @db.VarChar(200)
  preface         String?                 @map("preface") @db.Text
  page_count      Int                     @default(0) @map("page_count")
  person_count    Int                     @default(0) @map("person_count")
  estimated_price Decimal                 @default(0.00) @map("estimated_price") @db.Decimal(10, 2)
  status          FamilyBookStatus        @default(draft) @map("status")
  created_at      DateTime                @default(now()) @map("created_at")
  updated_at      DateTime                @updatedAt @map("updated_at")

