{
  "name": "geneasphere",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server start:dev",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.7.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "element-plus": "^2.14.2",
    "esbuild": "^0.28.1"
  }
}
